<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Music - Music Vault</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">All Music</h1>
          <a href="/music/create" class="btn btn-primary">Upload Music</a>
        </div>
        <% if (messages.error) { %>
          <div class="alert alert-danger"><%= messages.error %></div>
        <% } %>
        <% if (messages.success) { %>
          <div class="alert alert-success"><%= messages.success %></div>
        <% } %>
        <div class="mb-3">
          <form method="GET" class="d-flex">
            <input type="text" name="search" class="form-control me-2" placeholder="Search music..." value="<%= search %>">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
          </form>
        </div>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th><a href="?sort=title&order=<%= sort === 'title' && order === 1 ? 'desc' : 'asc' %>">Title</a></th>
                <th><a href="?sort=artist&order=<%= sort === 'artist' && order === 1 ? 'desc' : 'asc' %>">Artist</a></th>
                <th><a href="?sort=album&order=<%= sort === 'album' && order === 1 ? 'desc' : 'asc' %>">Album</a></th>
                <th><a href="?sort=genre&order=<%= sort === 'genre' && order === 1 ? 'desc' : 'asc' %>">Genre</a></th>
                <th><a href="?sort=year&order=<%= sort === 'year' && order === 1 ? 'desc' : 'asc' %>">Year</a></th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% music.forEach(song => { %>
                <tr>
                  <td><a href="/music/<%= song._id %>"><%= song.title %></a></td>
                  <td><%= song.artist %></td>
                  <td><%= song.album %></td>
                  <td><%= song.genre %></td>
                  <td><%= song.year %></td>
                  <td>
                    <a href="/music/<%= song._id %>" class="btn btn-sm btn-info">View</a>
                    <a href="/music/<%= song._id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                    <form action="/music/<%= song._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure?')">
                      <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <nav aria-label="Page navigation">
          <ul class="pagination">
            <% for (let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&order=<%= order === 1 ? 'asc' : 'desc' %>"><%= i %></a>
              </li>
            <% } %>
          </ul>
        </nav>
      </main>
    </div>
  </div>
  <!-- Floating Action Button -->
  <button class="fab" onclick="window.location.href='/music/create'" title="Quick Upload Music">
    <i class="fas fa-plus"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
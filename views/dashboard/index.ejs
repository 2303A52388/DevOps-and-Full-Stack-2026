<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Music Vault</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">Dashboard</h1>
        </div>
        <% if (messages.error) { %>
          <div class="alert alert-danger"><%= messages.error %></div>
        <% } %>
        <% if (messages.success) { %>
          <div class="alert alert-success"><%= messages.success %></div>
        <% } %>
        <div class="row">
          <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
              <div class="card-body">
                <h5 class="card-title">Total Songs</h5>
                <h2><%= totalSongs %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
              <div class="card-body">
                <h5 class="card-title">Total Users</h5>
                <h2><%= totalUsers %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
              <div class="card-body">
                <h5 class="card-title">Recent Uploads</h5>
                <h2><%= recentUploads.length %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
              <div class="card-body">
                <h5 class="card-title">Storage Used</h5>
                <h2><%= (storageUsed / 1024 / 1024).toFixed(2) %> MB</h2>
              </div>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Songs Uploaded per Month</div>
              <div class="card-body">
                <canvas id="monthlyChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Songs by Genre</div>
              <div class="card-body">
                <canvas id="genreChart"></canvas>
              </div>
            </div>
          </div>
        </div>
        <div class="row mt-4">
          <div class="col-md-12">
            <div class="card">
              <div class="card-header">Recent Uploads</div>
              <div class="card-body">
                <ul class="list-group list-group-flush">
                  <% recentUploads.forEach(upload => { %>
                    <li class="list-group-item">
                      <strong><%= upload.title %></strong> by <%= upload.artist %> - Uploaded by <%= upload.uploadedBy.name %>
                    </li>
                  <% }); %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
  <!-- Floating Action Button -->
  <button class="fab" onclick="window.location.href='/music/create'" title="Quick Upload Music">
    <i class="fas fa-plus"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const monthlyData = <%= monthlyUploads %>;
    const genreData = <%= genreDistribution %>;

    const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
    new Chart(monthlyCtx, {
      type: 'bar',
      data: {
        labels: monthlyData.map(d => `${d._id.month}/${d._id.year}`),
        datasets: [{
          label: 'Songs Uploaded',
          data: monthlyData.map(d => d.count),
          backgroundColor: 'rgba(54, 162, 235, 0.2)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 1
        }]
      }
    });

    const genreCtx = document.getElementById('genreChart').getContext('2d');
    new Chart(genreCtx, {
      type: 'pie',
      data: {
        labels: genreData.map(d => d._id),
        datasets: [{
          data: genreData.map(d => d.count),
          backgroundColor: [
            'rgba(255, 99, 132, 0.2)',
            'rgba(54, 162, 235, 0.2)',
            'rgba(255, 205, 86, 0.2)',
            'rgba(75, 192, 192, 0.2)',
            'rgba(153, 102, 255, 0.2)'
          ],
          borderColor: [
            'rgba(255, 99, 132, 1)',
            'rgba(54, 162, 235, 1)',
            'rgba(255, 205, 86, 1)',
            'rgba(75, 192, 192, 1)',
            'rgba(153, 102, 255, 1)'
          ],
          borderWidth: 1
        }]
      }
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>